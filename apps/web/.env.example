# Локальная проверка API: прокси /v1 → этот хост (uvicorn), путь /v1/... без /api
# Пример: VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000
# Пусто = dev-запросы /v1 идут на https://api.delez-repo.ru/api/v1
VITE_DEV_API_PROXY_TARGET=

# URL Python backend
VITE_API_URL=
# ID ассистента
VITE_ASSISTANT_ID=
# Опционально, LangSmith API ключ (не нужно для локальной работы)
VITE_LANGSMITH_API_KEY=

# Basic Auth credentials для API (обязательные)
VITE_API_USERNAME=
VITE_API_PASSWORD=
