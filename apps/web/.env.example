# --- Backend API ---
# Адрес Python-сервера FastAPI (оставьте пустым для локальной разработки через Vite-прокси)
VITE_API_URL=

# Basic Auth
VITE_API_USERNAME=change_me
VITE_API_PASSWORD=change_me

# Опционально: ID ассистента GigaChat
VITE_ASSISTANT_ID=

# LangSmith API ключ (только для отладки!!!)
VITE_LANGSMITH_API_KEY=

# --- Desktop-клиент (Tauri) ---
# Путь к бинарнику whisper-cli
# WHISPER_CLI_PATH=/opt/delez/whisper-cli

# Путь к модели whisper (по умолчанию ~/.cache/delez/whisper/ggml-small.bin)
# WHISPER_MODEL_PATH=~/.cache/delez/whisper/ggml-small.bin

# Для обхода проблем с SSL в AppImage (использовать только при отладке!)
# WEBKIT_IGNORE_SSL_ERRORS=1
# NODE_TLS_REJECT_UNAUTHORIZED=0
