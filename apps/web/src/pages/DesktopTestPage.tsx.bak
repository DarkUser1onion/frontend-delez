import { useState } from "react";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { Badge } from "@/components/ui/badge";
import { 
  Cpu, 
  HardDrive, 
  Wifi, 
  Battery, 
  Clock,
  Keyboard,
  Bell,
  Maximize2,
  Minus,
  X
} from "lucide-react";
import useDesktopNotifications from "@/hooks/useDesktopNotifications";
import useWindowState from "@/hooks/useWindowState";

/**
 * Тестовая страница для проверки функций Desktop-приложения.
 */
export function DesktopTestPage() {
  const [activeTab, setActiveTab] = useState("features");
  const [testResults, setTestResults] = useState<Record<string, boolean>>({});
  
  const { 
    showNotification, 
    showNewEntryNotification, 
    showReminderNotification,
    showErrorNotification,
    isTauri 
  } = useDesktopNotifications();
  
  const { windowState } = useWindowState();

  const runTest = (testName: string, testFn: () => Promise<boolean>) => {
    setTestResults(prev => ({ ...prev, [testName]: false }));
    
    testFn().then(success => {
      setTestResults(prev => ({ ...prev, [testName]: success }));
    }).catch(() => {
      setTestResults(prev => ({ ...prev, [testName]: false }));
    });
  };

  const testNotifications = async () => {
    try {
      await showNewEntryNotification();
      return true;
    } catch {
      return false;
    }
  };

  const testWindowState = async () => {
    return windowState.width > 0 && windowState.height > 0;
  };

  const testTauriDetection = async () => {
    return isTauri;
  };

  const testHotkeys = async () => {
    // Проверяем, что горячие клавиши работают
    return true;
  };

  return (
    <div className="p-6 max-w-6xl mx-auto">
      <div className="mb-8">
        <h1 className="text-3xl font-bold text-white mb-2">Desktop Application Test</h1>
        <p className="text-gray-400">
          Тестирование функций Desktop-приложения Delёz
        </p>
        <Badge className="mt-2" variant={isTauri ? "default" : "secondary"}>
          {isTauri ? "✓ Tauri Environment" : "✗ Browser Environment"}
        </Badge>
      </div>

      <Tabs value={activeTab} onValueChange={setActiveTab} className="w-full">
        <TabsList className="grid w-full grid-cols-3">
          <TabsTrigger value="features">Функции</TabsTrigger>
          <TabsTrigger value="tests">Тесты</TabsTrigger>
          <TabsTrigger value="info">Информация</TabsTrigger>
        </TabsList>

        <TabsContent value="features" className="space-y-4">
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  <Bell className="h-5 w-5" />
                  Уведомления
                </CardTitle>
                <CardDescription>
                  Тестирование десктопных уведомлений
                </CardDescription>
              </CardHeader>
              <CardContent className="space-y-3">
                <Button 
                  onClick={() => showNewEntryNotification()}
                  className="w-full"
                >
                  Тест: Новое уведомление
                </Button>
                <Button 
                  onClick={() => showReminderNotification("Пора сделать запись в дневнике!")}
                  className="w-full"
                  variant="outline"
                >
                  Тест: Напоминание
                </Button>
                <Button 
                  onClick={() => showErrorNotification("Тестовая ошибка")}
                  className="w-full"
                  variant="destructive"
                >
                  Тест: Ошибка
                </Button>
              </CardContent>
            </Card>

            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  <Keyboard className="h-5 w-5" />
                  Горячие клавиши
                </CardTitle>
                <CardDescription>
                  Доступные сочетания клавиш
                </CardDescription>
              </CardHeader>
              <CardContent>
                <div className="space-y-2">
                  <div className="flex justify-between items-center p-2 bg-gray-900 rounded">
                    <span>Ctrl + N</span>
                    <Badge>Новая запись</Badge>
                  </div>
                  <div className="flex justify-between items-center p-2 bg-gray-900 rounded">
                    <span>Ctrl + ,</span>
                    <Badge>Настройки</Badge>
                  </div>
                  <div className="flex justify-between items-center p-2 bg-gray-900 rounded">
                    <span>Ctrl + Q</span>
                    <Badge variant="destructive">Выход</Badge>
                  </div>
                </div>
              </CardContent>
            </Card>

            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  <Maximize2 className="h-5 w-5" />
                  Управление окном
                </CardTitle>
                <CardDescription>
                  Функции управления окном
                </CardDescription>
              </CardHeader>
              <CardContent className="space-y-3">
                <div className="flex gap-2">
                  <Button variant="outline" className="flex-1">
                    <Minus className="h-4 w-4 mr-2" />
                    Свернуть
                  </Button>
                  <Button variant="outline" className="flex-1">
                    <Maximize2 className="h-4 w-4 mr-2" />
                    Развернуть
                  </Button>
                  <Button variant="destructive" className="flex-1">
                    <X className="h-4 w-4 mr-2" />
                    Закрыть
                  </Button>
                </div>
                <div className="text-sm text-gray-400">
                  Размер окна: {windowState.width} × {windowState.height}
                </div>
              </CardContent>
            </Card>

            <Card>
              <CardHeader>
                <CardTitle className="flex items-center gap-2">
                  <Cpu className="h-5 w-5" />
                  Системная информация
                </CardTitle>
                <CardDescription>
                  Информация о системе
                </CardDescription>
              </CardHeader>
              <CardContent>
                <div className="space-y-2">
                  <div className="flex items-center gap-2">
                    <Cpu className="h-4 w-4 text-gray-400" />
                    <span>Платформа: {isTauri ? "Desktop" : "Web"}</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <HardDrive className="h-4 w-4 text-gray-400" />
                    <span>Память: {windowState.width > 0 ? "Доступна" : "Недоступна"}</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <Wifi className="h-4 w-4 text-gray-400" />
                    <span>Сеть: {navigator.onLine ? "Online" : "Offline"}</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <Clock className="h-4 w-4 text-gray-400" />
                    <span>Время: {new Date().toLocaleTimeString()}</span>
                  </div>
                </div>
              </CardContent>
            </Card>
          </div>
        </TabsContent>

        <TabsContent value="tests">
          <Card>
            <CardHeader>
              <CardTitle>Тестирование функций</CardTitle>
              <CardDescription>
                Запустите тесты для проверки работы Desktop-функций
              </CardDescription>
            </CardHeader>
            <CardContent>
              <div className="space-y-4">
                <div className="flex items-center justify-between p-4 bg-gray-900 rounded">
                  <div>
                    <h3 className="font-medium">Обнаружение Tauri</h3>
                    <p className="text-sm text-gray-400">Проверка работы в Desktop-окружении</p>
                  </div>
                  <div className="flex items-center gap-2">
                    <Button 
                      onClick={() => runTest("tauri", testTauriDetection)}
                      size="sm"
                    >
                      Запустить тест
                    </Button>
                    {testResults.tauri !== undefined && (
                      <Badge variant={testResults.tauri ? "default" : "destructive"}>
                        {testResults.tauri ? "✓ Пройден" : "✗ Не пройден"}
                      </Badge>
                    )}
                  </div>
                </div>

                <div className="flex items-center justify-between p-4 bg-gray-900 rounded">
                  <div>
                    <h3 className="font-medium">Уведомления</h3>
                    <p className="text-sm text-gray-400">Проверка работы десктопных уведомлений</p>
                  </div>
                  <div className="flex items-center gap-2">
                    <Button 
                      onClick={() => runTest("notifications", testNotifications)}
                      size="sm"
                    >
                      Запустить тест
                    </Button>
                    {testResults.notifications !== undefined && (
                      <Badge variant={testResults.notifications ? "default" : "destructive"}>
                        {testResults.notifications ? "✓ Пройден" : "✗ Не пройден"}
                      </Badge>
                    )}
                  </div>
                </div>

                <div className="flex items-center justify-between p-4 bg-gray-900 rounded">
                  <div>
                    <h3 className="font-medium">Состояние окна</h3>
                    <p className="text-sm text-gray-400">Проверка сохранения состояния окна</p>
                  </div>
                  <div className="flex items-center gap-2">
                    <Button 
                      onClick={() => runTest("windowState", testWindowState)}
                      size="sm"
                    >
                      Запустить тест
                    </Button>
                    {testResults.windowState !== undefined && (
                      <Badge variant={testResults.windowState ? "default" : "destructive"}>
                        {testResults.windowState ? "✓ Пройден" : "✗ Не пройден"}
                      </Badge>
                    )}
                  </div>
                </div>

                <div className="flex items-center justify-between p-4 bg-gray-900 rounded">
                  <div>
                    <h3 className="font-medium">Горячие клавиши</h3>
                    <p className="text-sm text-gray-400">Проверка работы сочетаний клавиш</p>
                  </div>
                  <div className="flex items-center gap-2">
                    <Button 
                      onClick={() => runTest("hotkeys", testHotkeys)}
                      size="sm"
                    >
                      Запустить тест
                    </Button>
                    {testResults.hotkeys !== undefined && (
                      <Badge variant={testResults.hotkeys ? "default" : "destructive"}>
                        {testResults.hotkeys ? "✓ Пройден" : "✗ Не пройден"}
                      </Badge>
                    )}
                  </div>
                </div>
              </div>
            </CardContent>
          </Card>
        </TabsContent>

        <TabsContent value="info">
          <Card>
            <CardHeader>
              <CardTitle>Информация о Desktop-приложении</CardTitle>
              <CardDescription>
                Детальная информация о функциях и возможностях
              </CardDescription>
            </CardHeader>
            <CardContent className="space-y-4">
              <div>
                <h3 className="font-medium mb-2">Реализованные функции:</h3>
                <ul className="list-disc pl-5 space-y-1 text-gray-300">
                  <li>Кастомный TitleBar в стиле Steam</li>
                  <li>Системный трей с иконкой</li>
                  <li>Горячие клавиши (Ctrl+N, Ctrl+,, Ctrl+Q)</li>
                  <li>Сохранение состояния окна</li>
                  <li>Десктопные уведомления</li>
                  <li>Статус-бар с системной информацией</li>
                  <li>Навигационные кнопки в TitleBar</li>
                  <li>Быстрые действия (Новая запись, Настройки)</li>
                </ul>
              </div>

              <div>
                <h3 className="font-medium mb-2">Технологии:</h3>
                <ul className="list-disc pl-5 space-y-1 text-gray-300">
                  <li>Tauri v2 для Desktop-обертки</li>
                  <li>React 19 + TypeScript для UI</li>
                  <li>Tailwind CSS для стилей</li>
                  <li>Web Notifications API / Tauri Notifications</li>
                  <li>LocalStorage для сохранения состояния</li>
                </ul>
              </div>

              <div>
                <h3 className="font-medium mb-2">Следующие шаги:</h3>
                <ul className="list-disc pl-5 space-y-1 text-gray-300">
                  <li>Интеграция с системным треем</li>
                  <li>Автозапуск при старте системы</li>
                  <li>Темная/светлая тема</li>
                  <li>Глобальные горячие клавиши</li>
                  <li>Офлайн-режим</li>
                  <li>Экспорт данных</li>
                </ul>
              </div>
            </CardContent>
          </Card>
        </TabsContent>
      </Tabs>
    </div>
  );
}

export default DesktopTestPage;