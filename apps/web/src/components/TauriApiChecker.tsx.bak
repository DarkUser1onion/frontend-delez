import React, { useState, useEffect } from "react";

export function TauriApiChecker() {
  const [checks, setChecks] = useState<Array<{name: string, result: boolean, details: string}>>([]);
  const [isTauri, setIsTauri] = useState(false);

  useEffect(() => {
    const performChecks = () => {
      const newChecks: Array<{name: string, result: boolean, details: string}> = [];
      
      // Check 1: __TAURI_INTERNALS__
      const hasInternals = !!(window as any).__TAURI_INTERNALS__;
      newChecks.push({
        name: '__TAURI_INTERNALS__',
        result: hasInternals,
        details: hasInternals ? 'Present' : 'Not found'
      });
      
      // Check 2: __TAURI__
      const hasTauri = !!(window as any).__TAURI__;
      newChecks.push({
        name: '__TAURI__',
        result: hasTauri,
        details: hasTauri ? 'Present' : 'Not found (normal for Tauri v2)'
      });
      
      // Check 3: __TAURI_IPC__
      const hasIpc = !!(window as any).__TAURI_IPC__;
      newChecks.push({
        name: '__TAURI_IPC__',
        result: hasIpc,
        details: hasIpc ? 'Present' : 'Not found'
      });
      
      // Check 4: Check internals structure
      if (hasInternals) {
        const internals = (window as any).__TAURI_INTERNALS__;
        const keys = Object.keys(internals);
        newChecks.push({
          name: 'Internals Keys',
          result: keys.length > 0,
          details: keys.join(', ')
        });
        
        // Check for window API
        if (internals.window) {
          const windowMethods = Object.keys(internals.window);
          newChecks.push({
            name: 'Window API',
            result: windowMethods.length > 0,
            details: `Methods: ${windowMethods.join(', ')}`
          });
        } else {
          newChecks.push({
            name: 'Window API',
            result: false,
            details: 'Not found in internals'
          });
        }
        
        // Check for event API
        if (internals.event) {
          const eventMethods = Object.keys(internals.event);
          newChecks.push({
            name: 'Event API',
            result: eventMethods.length > 0,
            details: `Methods: ${eventMethods.join(', ')}`
          });
        } else {
          newChecks.push({
            name: 'Event API',
            result: false,
            details: 'Not found in internals'
          });
        }
      }
      
      // Check 5: Try to access window methods directly
      try {
        if (hasInternals && (window as any).__TAURI_INTERNALS__.window) {
          const windowApi = (window as any).__TAURI_INTERNALS__.window;
          const testMethods = ['minimize', 'close', 'isMaximized'];
          const availableMethods = testMethods.filter(m => typeof windowApi[m] === 'function');
          
          newChecks.push({
            name: 'Direct Window Access',
            result: availableMethods.length > 0,
            details: `Available: ${availableMethods.join(', ')}`
          });
        }
      } catch (error) {
        newChecks.push({
          name: 'Direct Window Access',
          result: false,
          details: `Error: ${error}`
        });
      }
      
      setChecks(newChecks);
      setIsTauri(hasInternals || hasTauri || hasIpc);
    };
    
    // Perform checks immediately and after delays
    performChecks();
    const timeout1 = setTimeout(performChecks, 1000);
    const timeout2 = setTimeout(performChecks, 3000);
    const timeout3 = setTimeout(performChecks, 5000);
    
    return () => {
      clearTimeout(timeout1);
      clearTimeout(timeout2);
      clearTimeout(timeout3);
    };
  }, []);

  const testDirectMinimize = async () => {
    try {
      if ((window as any).__TAURI_INTERNALS__?.window?.minimize) {
        await (window as any).__TAURI_INTERNALS__.window.minimize();
        alert('Minimize command sent successfully!');
      } else {
        alert('Minimize method not found');
      }
    } catch (error) {
      alert(`Minimize error: ${error}`);
    }
  };

  const testDirectClose = async () => {
    try {
      if ((window as any).__TAURI_INTERNALS__?.window?.close) {
        await (window as any).__TAURI_INTERNALS__.window.close();
        alert('Close command sent successfully!');
      } else {
        alert('Close method not found');
      }
    } catch (error) {
      alert(`Close error: ${error}`);
    }
  };

  if (!isTauri) {
    return (
      <div style={{
        position: "fixed",
        top: "10px",
        left: "10px",
        background: "#ff4444",
        color: "white",
        padding: "10px",
        borderRadius: "4px",
        fontSize: "12px",
        zIndex: 9999
      }}>
        Not running in Tauri environment
      </div>
    );
  }

  return (
    <div style={{
      position: "fixed",
      top: "10px",
      left: "10px",
      background: "#1a1a2e",
      border: "1px solid #3a3a6a",
      borderRadius: "8px",
      padding: "15px",
      fontSize: "12px",
      color: "#c6d4df",
      zIndex: 9999,
      maxWidth: "400px",
      maxHeight: "500px",
      overflow: "auto"
    }}>
      <h3 style={{ margin: "0 0 10px 0", color: "#66c0f4" }}>Tauri API Checker</h3>
      
      <div style={{ marginBottom: "10px" }}>
        {checks.map((check, index) => (
          <div key={index} style={{ 
            marginBottom: "5px",
            padding: "5px",
            background: check.result ? "rgba(76, 175, 80, 0.1)" : "rgba(244, 67, 54, 0.1)",
            borderRadius: "4px",
            borderLeft: `3px solid ${check.result ? "#4caf50" : "#f44336"}`
          }}>
            <div style={{ fontWeight: "bold" }}>{check.name}</div>
            <div style={{ fontSize: "11px", opacity: 0.8 }}>{check.details}</div>
          </div>
        ))}
      </div>
      
      <div style={{ 
        display: "flex", 
        gap: "5px",
        marginTop: "10px"
      }}>
        <button 
          onClick={testDirectMinimize}
          style={{
            padding: "5px 10px",
            background: "#2a2a4a",
            border: "1px solid #3a3a6a",
            color: "#c6d4df",
            borderRadius: "4px",
            cursor: "pointer",
            fontSize: "11px"
          }}
        >
          Test Direct Minimize
        </button>
        
        <button 
          onClick={testDirectClose}
          style={{
            padding: "5px 10px",
            background: "#e81123",
            border: "1px solid #ff3344",
            color: "white",
            borderRadius: "4px",
            cursor: "pointer",
            fontSize: "11px"
          }}
        >
          Test Direct Close
        </button>
      </div>
      
      <div style={{ 
        marginTop: "10px", 
        fontSize: "10px", 
        opacity: 0.7,
        borderTop: "1px solid rgba(255, 255, 255, 0.1)",
        paddingTop: "10px"
      }}>
        <p>If direct methods work but our API doesn't, there's an issue with our API implementation.</p>
        <p>Try testing in browser console:</p>
        <code style={{ display: "block", marginTop: "5px" }}>
          window.__TAURI_INTERNALS__?.window?.minimize()
        </code>
      </div>
    </div>
  );
}

export default TauriApiChecker;