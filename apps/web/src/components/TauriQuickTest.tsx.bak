import React, { useState, useEffect } from "react";

export function TauriQuickTest() {
  const [status, setStatus] = useState("Проверка...");
  const [apiAvailable, setApiAvailable] = useState(false);

  useEffect(() => {
    const checkTauri = () => {
      const win = window as any;
      
      if (win.__TAURI_INTERNALS__) {
        setStatus("Tauri обнаружен! ✓");
        setApiAvailable(true);
        
        // Проверяем доступные методы
        const internals = win.__TAURI_INTERNALS__;
        let methods = [];
        
        if (internals.window) {
          methods.push(`Window: ${Object.keys(internals.window).join(', ')}`);
        }
        
        if (internals.event) {
          methods.push(`Event: ${Object.keys(internals.event).join(', ')}`);
        }
        
        console.log("Tauri API доступен:", methods);
      } else {
        setStatus("Tauri не обнаружен ✗");
        setApiAvailable(false);
      }
    };
    
    checkTauri();
    const interval = setInterval(checkTauri, 2000);
    
    return () => clearInterval(interval);
  }, []);

  const testDirectCall = async (method: string) => {
    const win = window as any;
    
    if (!win.__TAURI_INTERNALS__) {
      alert("Tauri API не доступен");
      return;
    }
    
    try {
      switch (method) {
        case 'minimize':
          if (win.__TAURI_INTERNALS__.window?.minimize) {
            await win.__TAURI_INTERNALS__.window.minimize();
            alert("Окно свернуто!");
          } else {
            alert("Метод minimize не найден");
          }
          break;
          
        case 'close':
          if (win.__TAURI_INTERNALS__.window?.close) {
            await win.__TAURI_INTERNALS__.window.close();
            alert("Команда закрытия отправлена!");
          } else {
            alert("Метод close не найден");
          }
          break;
          
        case 'emit-new-entry':
          if (win.__TAURI_INTERNALS__.event?.emit) {
            await win.__TAURI_INTERNALS__.event.emit("new-entry", {});
            alert("Событие new-entry отправлено!");
          } else {
            alert("Метод emit не найден");
          }
          break;
      }
    } catch (error) {
      alert(`Ошибка: ${error}`);
    }
  };

  return (
    <div style={{
      position: "fixed",
      bottom: "10px",
      right: "10px",
      background: apiAvailable ? "#1a2e1a" : "#2e1a1a",
      border: `1px solid ${apiAvailable ? "#3a6a3a" : "#6a3a3a"}`,
      borderRadius: "8px",
      padding: "10px",
      fontSize: "12px",
      color: "#c6d4df",
      zIndex: 9999,
      maxWidth: "250px"
    }}>
      <div style={{ fontWeight: "bold", marginBottom: "5px" }}>
        Tauri Quick Test
      </div>
      
      <div style={{ 
        marginBottom: "10px",
        padding: "5px",
        background: "#000000",
        borderRadius: "4px",
        fontSize: "11px"
      }}>
        {status}
      </div>
      
      {apiAvailable && (
        <div style={{ display: "flex", flexDirection: "column", gap: "5px" }}>
          <button 
            onClick={() => testDirectCall('minimize')}
            style={{
              padding: "5px 10px",
              background: "#2a2a4a",
              border: "1px solid #3a3a6a",
              color: "#c6d4df",
              borderRadius: "4px",
              cursor: "pointer",
              fontSize: "11px"
            }}
          >
            Тест: Свернуть
          </button>
          
          <button 
            onClick={() => testDirectCall('close')}
            style={{
              padding: "5px 10px",
              background: "#e81123",
              border: "1px solid #ff3344",
              color: "white",
              borderRadius: "4px",
              cursor: "pointer",
              fontSize: "11px"
            }}
          >
            Тест: Закрыть
          </button>
          
          <button 
            onClick={() => testDirectCall('emit-new-entry')}
            style={{
              padding: "5px 10px",
              background: "#2a4a2a",
              border: "1px solid #3a6a3a",
              color: "#c6d4df",
              borderRadius: "4px",
              cursor: "pointer",
              fontSize: "11px"
            }}
          >
            Тест: New Entry
          </button>
        </div>
      )}
      
      <div style={{ 
        marginTop: "10px", 
        fontSize: "10px", 
        opacity: 0.7,
        borderTop: "1px solid rgba(255, 255, 255, 0.1)",
        paddingTop: "10px"
      }}>
        <div>Откройте консоль (F12) и проверьте:</div>
        <code style={{ display: "block", marginTop: "5px" }}>
          window.__TAURI_INTERNALS__
        </code>
      </div>
    </div>
  );
}

export default TauriQuickTest;